<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ── Üst bar ──────────────────────────────────────────────── -->
    <RelativeLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="TouchNav"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btn_theme_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="☀"
            android:textSize="20sp"/>
    </RelativeLayout>

    <!-- ── Logo alanı ───────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Canvas logo -->
        <View
            android:id="@+id/logo_view"
            android:layout_width="96dp"
            android:layout_height="96dp"/>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TouchNav"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YÜZEN NAVİGASYON"
            android:textSize="12sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp"/>

        <!-- Durum rozeti -->
        <LinearLayout
            android:id="@+id/status_badge"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:layout_marginBottom="28dp">

            <View
                android:id="@+id/status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginRight="8dp"/>

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servis Durduruldu"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Ana toggle butonu -->
        <Button
            android:id="@+id/btn_toggle"
            android:layout_width="220dp"
            android:layout_height="54dp"
            android:text="▶  Başlat"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp"/>

        <!-- Ayarlar butonu -->
        <Button
            android:id="@+id/btn_settings"
            android:layout_width="180dp"
            android:layout_height="44dp"
            android:text="⚙  Ayarlar"
            android:textSize="14sp"/>

    </LinearLayout>

    <!-- ── Alt not ───────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Erişilebilirlik izni: Ayarlar → Erişilebilirlik → TouchNav"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingBottom="24dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"/>

</LinearLayout>
